config_version=5

[application]
config/name="El Bárbaro"
config/description="Action RPG Roguelite"
run/main_scene="res://scenes/Boot.tscn"
config/features=PackedStringArray("4.7")
boot_splash/bg_color=Color(0.05, 0.05, 0.05, 1)

[autoload]
EventBus="*res://scripts/core/event_bus.gd"
Logger="*res://scripts/core/logger.gd"
ConfigManager="*res://scripts/core/config_manager.gd"
GameManager="*res://scripts/Autoload/GameManager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
MetaKnowledge="*res://scripts/Autoload/MetaKnowledge.gd"
PlayerData="*res://scripts/Autoload/PlayerData.gd"
RunData="*res://scripts/Autoload/RunData.gd"
NotificationSystem="*res://scripts/Autoload/NotificationSystem.gd"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/dpi/allow_hidpi=true

